# Copy to .env (gitignored) and fill in real values.
# Never commit real keys.

# ----------------------------------------------------------------------
# Brain core
# ----------------------------------------------------------------------
BRAIN_DEFAULT_MODEL=gpt-4o-mini
BRAIN_DEFAULT_LAYER=L1
BRAIN_LOG_LEVEL=INFO
BRAIN_LLM_TIMEOUT_SECONDS=30
BRAIN_EMBED_MODEL_PATH=models/bge-m3
BRAIN_RERANK_MODEL_PATH=models/bge-reranker-v2-m3
BRAIN_ES_INDEX_NAME=hotspot_search

# ----------------------------------------------------------------------
# LLM providers (ADR 0006: V1 = GPT + Claude only)
# ----------------------------------------------------------------------
# Filled when actually wiring real LLM calls.
OPENAI_API_KEY=
# Local OpenAI-compatible gateway example. Keep the trailing `/v1`.
OPENAI_BASE_URL=http://localhost:17654/v1
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------
# Langfuse self-hosted observability
# ----------------------------------------------------------------------
# After `docker compose up -d` in infra/langfuse/, register an account
# at http://localhost:3000, create a project, copy keys here.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PROMPT_FETCH_ENABLED=false

# ----------------------------------------------------------------------
# Elasticsearch shared with fullstack-product/docker compose.
# ----------------------------------------------------------------------
BRAIN_ES_URL=http://localhost:9200
BRAIN_ES_USER=
BRAIN_ES_PASS=
